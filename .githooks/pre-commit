#!/usr/bin/env bash
set -euo pipefail
VAULT=~/Documents/vaults/jarvis-one

if command -v gitleaks &>/dev/null; then
  gitleaks protect --staged --no-banner || exit 1
fi

set +e
python3 "$VAULT/.ai/tools/swoop-1d-audit.py" --repo .
audit_status=$?
set -e
if [[ "$audit_status" -eq 1 ]]; then
  exit 1
fi
if [[ "$audit_status" -ne 0 && "$audit_status" -ne 2 ]]; then
  exit "$audit_status"
fi
python3 "$VAULT/.ai/tools/cli_parity_audit.py" --repo . || exit 1
# Jarvis One parity gate
if [[ -x "/Users/samsavitt/Documents/vaults/jarvis-one/.ai/hooks/pre-commit-parity.sh" ]]; then
  (cd "/Users/samsavitt/Documents/vaults/jarvis-one" && .ai/hooks/pre-commit-parity.sh)
else
  echo "Jarvis One parity hook missing or not executable" >&2
  exit 1
fi
# Jarvis One NEXT-freshness gate — keeps the repo's handoff surface current
python3 "/Users/samsavitt/Documents/vaults/jarvis-one/.ai/tools/next_freshness.py" || exit 1
